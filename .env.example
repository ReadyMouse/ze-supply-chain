# Copy to .env and fill in. NEVER commit .env — the seed controls real ZEC.

# 24-word BIP 39 mnemonic for the org wallet. Generate once with:
#   cargo run -p wallet-service -- gen-seed
WALLET_SEED_PHRASE=""

# Wallet birthday: mainnet block height at the time the seed was created.
# The scanner starts here; nothing earlier is ever examined.
WALLET_BIRTHDAY=3000000

DATABASE_URL=postgres://audit:audit@localhost:5432/audit
# The operator-run lightwalletd gRPC endpoint — fill in when the node is online.
# (Public endpoints like https://zec.rocks:443 also speak this protocol.)
LIGHTWALLETD_URL=http://CHANGE-ME:9067
WALLET_DB_PATH=./data/wallet/wallet.sqlite

WALLET_SERVICE_ADDR=127.0.0.1:7001
# 7700 because macOS AirPlay squats on 5000/7000
GATEWAY_ADDR=127.0.0.1:7700

# Batching policy
BATCH_MAX_RECORDS=5
BATCH_MAX_AGE_SECS=120
